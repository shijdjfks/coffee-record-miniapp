<view class="container">
  <view class="nav-bar">
    <view class="nav-left"></view>
    <view class="nav-title">Brewlog</view>
    <view class="nav-home" bindtap="goHome">
      <text class="home-icon">🏠</text>
    </view>
  </view>

  <view class="logo-section">
    <view class="logo-icon">☕</view>
    <view class="app-name">个人咖啡手帐</view>
    <view class="app-slogan">记录每一杯咖啡的美好</view>
  </view>

  <view class="welcome-card">
    <view class="welcome-text">欢迎来到你的</view>
    <view class="welcome-text accent">咖啡时光</view>
  </view>

  <view class="features-grid">
    <view class="feature-card" bindtap="goToAddRecord">
      <view class="feature-card-icon">📝</view>
      <view class="feature-card-title">记录咖啡</view>
      <view class="feature-card-subtitle">每日咖啡时光</view>
    </view>
    <view class="feature-card" bindtap="goToStats">
      <view class="feature-card-icon">📊</view>
      <view class="feature-card-title">统计图表</view>
      <view class="feature-card-subtitle">喝咖啡习惯</view>
    </view>
    <view class="feature-card" bindtap="goToCamera">
      <view class="feature-card-icon">📸</view>
      <view class="feature-card-title">拍照留念</view>
      <view class="feature-card-subtitle">记录美好瞬间</view>
    </view>
    <view class="feature-card" bindtap="getUserProfile">
      <view class="feature-card-icon">👤</view>
      <view class="feature-card-title">个人中心</view>
      <view class="feature-card-subtitle">登录/设置</view>
    </view>
  </view>

  <view class="login-section">
    <button 
      class="login-btn" 
      bindtap="getUserProfile"
      wx:if="{{canIUse}}"
    >
      <text class="btn-icon">🍵</text>
      <text class="btn-text">微信一键登录</text>
    </button>

    <view class="skip-btn" bindtap="skipLogin">
      稍后登录
    </view>
  </view>

  <view class="footer-text">
    登录即表示同意《用户协议》和《隐私政策》
  </view>
</view>
