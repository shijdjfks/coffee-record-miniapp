.container {
  min-height: 100vh;
  background: var(--coffee-bg);
  padding-bottom: 140rpx;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #FFF;
  border-bottom: 2rpx solid var(--coffee-lightest);
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--coffee-lightest);
  border-radius: 50%;
  font-size: 48rpx;
  color: var(--coffee-darker);
  font-weight: 300;
  margin-top: -4rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--coffee-darker);
}

.nav-right {
  width: 64rpx;
  height: 64rpx;
}

/* 动态卡片 */
.post-card {
  background: #FFF;
  margin: 16rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(139, 90, 43, 0.06);
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--coffee-lightest);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 16rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--coffee-darker);
}

.post-time {
  font-size: 22rpx;
  color: var(--coffee-light);
  margin-top: 4rpx;
}

.post-text {
  font-size: 30rpx;
  color: var(--coffee-darker);
  line-height: 1.6;
  margin-bottom: 16rpx;
  word-break: break-all;
}

.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.post-image {
  width: 220rpx;
  height: 220rpx;
  background: var(--coffee-lightest);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-emoji {
  font-size: 96rpx;
}

.post-location {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: var(--coffee-lightest);
  border-radius: 30rpx;
  align-self: flex-start;
  margin-bottom: 16rpx;
}

.location-icon-small {
  font-size: 22rpx;
  margin-right: 8rpx;
}

.location-name-small {
  font-size: 22rpx;
  color: var(--coffee-medium);
}

.post-stats {
  display: flex;
  align-items: center;
  padding-top: 16rpx;
  border-top: 2rpx solid var(--coffee-lightest);
  gap: 48rpx;
}

.action-btn {
  display: flex;
  align-items: center;
}

.action-btn:active {
  opacity: 0.6;
}

.action-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.action-count {
  font-size: 24rpx;
  color: var(--coffee-light);
}

.action-btn.liked .action-count {
  color: #E84A5F;
  font-weight: 600;
}

/* 评论区 */
.comments-section {
  background: #FFF;
  margin: 0 16rpx 16rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(139, 90, 43, 0.06);
}

.comments-title {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--coffee-darker);
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid var(--coffee-lightest);
  margin-bottom: 16rpx;
}

.comments-count {
  font-size: 22rpx;
  color: var(--coffee-light);
  margin-left: 8rpx;
  font-weight: 400;
}

.comments-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.comment-item {
  display: flex;
  align-items: flex-start;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--coffee-lightest);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.comment-body {
  flex: 1;
}

.comment-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.comment-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--coffee-medium);
}

.comment-time {
  font-size: 20rpx;
  color: var(--coffee-light);
}

.comment-text {
  font-size: 28rpx;
  color: var(--coffee-darker);
  line-height: 1.5;
  word-break: break-all;
}

.comments-empty {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 24rpx;
  color: var(--coffee-light);
  white-space: pre-line;
}

/* 底部输入栏 */
.comment-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #FFF;
  border-top: 2rpx solid var(--coffee-lightest);
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.comment-input {
  flex: 1;
  height: 72rpx;
  background: var(--coffee-lightest);
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--coffee-darker);
}

.input-placeholder {
  color: var(--coffee-light);
  font-size: 26rpx;
}

.send-btn {
  margin-left: 16rpx;
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  color: var(--coffee-light);
  background: var(--coffee-lightest);
  border-radius: 36rpx;
}

.send-btn.active {
  background: linear-gradient(135deg, var(--coffee-dark) 0%, var(--coffee-medium) 100%);
  color: #FFF;
  font-weight: 600;
}

.send-btn:active {
  opacity: 0.7;
}
