.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF;
  border-radius: 50%;
  box-shadow: 0 2rpx 12rpx rgba(139, 90, 43, 0.1);
}

.back-icon {
  font-size: 32rpx;
  color: var(--coffee-darker);
  font-weight: 600;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--coffee-darker);
}

.nav-home {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF;
  border-radius: 50%;
  box-shadow: 0 2rpx 12rpx rgba(139, 90, 43, 0.1);
}

.home-icon {
  font-size: 28rpx;
}

.nav-home:active {
  background: var(--coffee-lightest);
}

.month-stats {
  background: var(--coffee-dark);
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
}

.month-stats .stat {
  color: #FFF;
  font-size: 24rpx;
  font-weight: 500;
}

.calendar {
  background: #FFF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(139, 90, 43, 0.1);
}

.weekday-row {
  display: flex;
  margin-bottom: 16rpx;
}

.weekday {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: var(--coffee-medium);
  font-weight: 600;
}

.days-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.day-cell {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: var(--coffee-lightest);
  transition: all 0.2s ease;
}

.day-cell.empty {
  background: transparent;
}

.day-cell.today {
  border: 2rpx solid var(--coffee-dark);
}

.day-cell.selected {
  background: var(--coffee-dark);
}

.day-cell.selected .day-number {
  color: #FFF;
}

.day-cell.has-record {
  background: linear-gradient(135deg, var(--coffee-light) 0%, var(--coffee-medium) 100%);
}

.day-number {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--coffee-darker);
}

.day-cups {
  display: flex;
  align-items: center;
  gap: 2rpx;
  margin-top: 2rpx;
}

.cup-icon-small {
  font-size: 16rpx;
}

.cup-num {
  font-size: 18rpx;
  font-weight: 600;
  color: var(--coffee-darker);
}

.quick-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #FFF;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(139, 90, 43, 0.08);
}

.camera-btn {
  border: 2rpx dashed var(--coffee-medium);
}

.action-icon {
  font-size: 32rpx;
}

.action-text {
  font-size: 24rpx;
  color: var(--coffee-darker);
  font-weight: 500;
}

.selected-day-detail {
  background: #FFF;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(139, 90, 43, 0.1);
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid var(--coffee-lightest);
}

.detail-date {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--coffee-darker);
}

.detail-count {
  font-size: 24rpx;
  color: var(--coffee-dark);
  font-weight: 600;
}

.records-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-card {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: var(--coffee-lightest);
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.record-card:active {
  background: var(--coffee-light);
}

.record-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.record-info {
  flex: 1;
}

.record-shop {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--coffee-darker);
}

.record-detail {
  font-size: 22rpx;
  color: var(--coffee-medium);
  margin-top: 4rpx;
}

.record-arrow {
  font-size: 36rpx;
  color: var(--coffee-light);
}

.no-records {
  text-align: center;
  padding: 40rpx;
  color: var(--coffee-medium);
  font-size: 24rpx;
}

.quick-add-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--coffee-darker);
  text-align: center;
  margin-bottom: 32rpx;
}

.photo-preview {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.photo-preview image {
  width: 100%;
  height: 100%;
}

.generated-result {
  text-align: center;
  margin-bottom: 32rpx;
}

.big-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.result-text {
  font-size: 26rpx;
  color: var(--coffee-medium);
}

.modal-actions {
  display: flex;
  gap: 16rpx;
}

.btn-cancel, .btn-confirm {
  flex: 1;
  padding: 20rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-cancel {
  background: var(--coffee-lightest);
  color: var(--coffee-darker);
}

.btn-confirm {
  background: linear-gradient(135deg, var(--coffee-dark) 0%, var(--coffee-darker) 100%);
  color: #FFF;
}
