.container {
  min-height: 100vh;
  background: var(--coffee-bg);
  padding: 24rpx;
  box-sizing: border-box;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF;
  border-radius: 50%;
  box-shadow: 0 2rpx 12rpx rgba(139, 90, 43, 0.1);
}

.back-icon {
  font-size: 48rpx;
  color: var(--coffee-darker);
  font-weight: 300;
  margin-top: -4rpx;
}

.nav-back:active {
  background: var(--coffee-lightest);
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--coffee-darker);
  letter-spacing: 2rpx;
}

.nav-right {
  width: 64rpx;
  height: 64rpx;
}

.register-header {
  text-align: center;
  padding: 24rpx 0 24rpx;
}

.logo-icon {
  font-size: 80rpx;
  margin-bottom: 12rpx;
}

.register-title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--coffee-darker);
  margin-bottom: 8rpx;
}

.register-subtitle {
  font-size: 24rpx;
  color: var(--coffee-light);
}

.register-card {
  background: #FFF;
  border-radius: 24rpx;
  padding: 8rpx 32rpx;
  margin: 16rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(139, 90, 43, 0.08);
}

.input-group {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  transition: all 0.3s ease;
}

.input-group.focused .input-icon {
  transform: scale(1.1);
}

.input-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  transition: transform 0.3s ease;
}

.input-field {
  flex: 1;
  font-size: 30rpx;
  color: var(--coffee-darker);
  height: 48rpx;
  line-height: 48rpx;
}

.input-placeholder {
  color: var(--coffee-light);
  font-size: 28rpx;
}

.input-divider {
  height: 2rpx;
  background: var(--coffee-lightest);
  margin: 0 -8rpx;
}

/* 验证码按钮 */
.code-group {
  position: relative;
}

.code-btn {
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, var(--coffee-dark) 0%, var(--coffee-medium) 100%);
  color: #FFF;
  font-size: 24rpx;
  border-radius: 40rpx;
  white-space: nowrap;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(139, 90, 43, 0.2);
}

.code-btn:active {
  transform: scale(0.96);
}

.code-btn.disabled {
  background: #CCC;
  color: #999;
  box-shadow: none;
}

.code-btn.disabled:active {
  transform: none;
}

/* 注册按钮 */
.register-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--coffee-dark) 0%, var(--coffee-medium) 100%);
  color: #FFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 50rpx;
  padding: 24rpx;
  margin-top: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(139, 90, 43, 0.3);
  letter-spacing: 8rpx;
}

.register-btn::after {
  border: none;
}

.register-btn:active {
  transform: scale(0.98);
  opacity: 0.95;
}

/* 其他方式登录分隔 */
.other-login {
  display: flex;
  align-items: center;
  margin: 48rpx 0 24rpx;
}

.other-login-divider {
  flex: 1;
  height: 2rpx;
  background: var(--coffee-light);
  opacity: 0.5;
}

.other-login-text {
  padding: 0 24rpx;
  font-size: 24rpx;
  color: var(--coffee-light);
}

/* 社交登录按钮 */
.social-buttons {
  display: flex;
  justify-content: center;
  gap: 80rpx;
}

.social-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.social-icon {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF;
  border-radius: 50%;
  font-size: 48rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(139, 90, 43, 0.1);
}

.social-btn:active .social-icon {
  transform: scale(0.95);
  background: var(--coffee-lightest);
}

.social-label {
  font-size: 24rpx;
  color: var(--coffee-medium);
}
