.header {
  margin-bottom: 24rpx;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.nav-left {
  width: 56rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--coffee-darker);
}

.nav-home {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(139, 90, 43, 0.1);
}

.home-icon {
  font-size: 28rpx;
}

.nav-home:active {
  background: var(--coffee-lightest);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--coffee-darker);
  margin-bottom: 16rpx;
}

.week-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.nav-btn {
  font-size: 44rpx;
  color: var(--coffee-dark);
  padding: 8rpx 24rpx;
  font-weight: 300;
}

.nav-btn:active {
  color: var(--coffee-darker);
}

.week-range {
  font-size: 26rpx;
  color: var(--coffee-darker);
  font-weight: 600;
}

.week-stats {
  background: linear-gradient(135deg, var(--coffee-dark) 0%, var(--coffee-darker) 100%);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  text-align: center;
}

.week-stats .stat {
  color: #FFF;
  font-size: 26rpx;
  font-weight: 500;
}

.week-days {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.day-card {
  background: #FFF;
  border-radius: 24rpx;
  padding: 20rpx;
  display: flex;
  align-items: flex-start;
  box-shadow: 0 4rpx 16rpx rgba(139, 90, 43, 0.08);
  transition: all 0.3s ease;
}

.day-card.today {
  border: 2rpx solid var(--coffee-dark);
  box-shadow: 0 4rpx 20rpx rgba(139, 90, 43, 0.15);
}

.day-card.has-record {
  background: linear-gradient(135deg, #FFF 0%, var(--coffee-lightest) 100%);
}

.day-date-circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--coffee-light) 0%, var(--coffee-medium) 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.today .day-date-circle {
  background: linear-gradient(135deg, var(--coffee-dark) 0%, var(--coffee-darker) 100%);
}

.day-name {
  font-size: 20rpx;
  color: #FFF;
  font-weight: 600;
  opacity: 0.9;
}

.day-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFF;
  line-height: 1;
}

.day-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-height: 88rpx;
  justify-content: center;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 16rpx;
  border: 1rpx solid var(--coffee-lightest);
}

.record-item:active {
  background: rgba(255, 255, 255, 0.6);
}

.record-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.record-avatar image {
  width: 100%;
  height: 100%;
}

.record-icon-box {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background: var(--coffee-lightest);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.record-icon {
  font-size: 36rpx;
}

.record-details {
  flex: 1;
}

.record-shop {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--coffee-darker);
  margin-bottom: 4rpx;
}

.record-meta {
  font-size: 22rpx;
  color: var(--coffee-medium);
}

.day-empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
}

.empty-cup {
  font-size: 40rpx;
  opacity: 0.4;
  margin-bottom: 4rpx;
}

.empty-text {
  font-size: 22rpx;
  color: var(--coffee-light);
}

.add-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--coffee-lightest);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.add-btn:active {
  background: var(--coffee-light);
}

.add-icon {
  font-size: 32rpx;
  color: var(--coffee-medium);
  font-weight: 300;
}

.add-floating {
  position: fixed;
  bottom: 60rpx;
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--coffee-dark) 0%, var(--coffee-darker) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(139, 90, 43, 0.4);
}

.add-floating:active {
  transform: scale(0.95);
}

.add-floating .add-icon {
  font-size: 48rpx;
  color: #FFF;
  font-weight: 300;
}
