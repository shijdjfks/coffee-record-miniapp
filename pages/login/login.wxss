.container {
  min-height: 100vh;
  background: var(--coffee-bg);
  padding: 24rpx;
  box-sizing: border-box;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.nav-left {
  width: 64rpx;
  height: 64rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--coffee-darker);
  letter-spacing: 2rpx;
}

.nav-home {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF;
  border-radius: 50%;
  box-shadow: 0 2rpx 12rpx rgba(139, 90, 43, 0.1);
}

.home-icon {
  font-size: 28rpx;
}

.nav-home:active {
  background: var(--coffee-lightest);
}

.logo-section {
  text-align: center;
  padding: 16rpx 0;
}

.logo-icon {
  font-size: 60rpx;
  margin-bottom: 8rpx;
}

.app-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--coffee-darker);
  margin-bottom: 4rpx;
}

.app-slogan {
  font-size: 22rpx;
  color: var(--coffee-light);
}

.welcome-card {
  background: linear-gradient(135deg, var(--coffee-dark) 0%, var(--coffee-medium) 100%);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 16rpx;
}

.welcome-text {
  font-size: 24rpx;
  color: #FFF;
  line-height: 1.4;
}

.welcome-text.accent {
  font-size: 28rpx;
  font-weight: 700;
  margin-top: 4rpx;
}

.features {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #FFF;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(139, 90, 43, 0.06);
}

.feature-item:active {
  background: var(--coffee-lightest);
}

.feature-icon {
  font-size: 28rpx;
}

.feature-text {
  flex: 1;
  font-size: 24rpx;
  color: var(--coffee-darker);
}

.feature-arrow {
  font-size: 28rpx;
  color: var(--coffee-light);
}

.year-section {
  background: #FFF;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(139, 90, 43, 0.06);
}

.year-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.year-nav {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.year-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--coffee-lightest);
  border-radius: 50%;
  font-size: 24rpx;
  color: var(--coffee-darker);
}

.year-btn:active {
  background: var(--coffee-light);
}

.year-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--coffee-darker);
}

.year-stats {
  display: flex;
  gap: 16rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--coffee-darker);
}

.stat-label {
  font-size: 18rpx;
  color: var(--coffee-light);
}

.months-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.month-card {
  background: var(--coffee-lightest);
  border-radius: 12rpx;
  padding: 12rpx;
  text-align: center;
}

.month-card.today {
  background: linear-gradient(135deg, var(--coffee-dark) 0%, var(--coffee-medium) 100%);
}

.month-card.empty {
  opacity: 0.5;
}

.month-card:active {
  transform: scale(0.95);
}

.month-name {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--coffee-light);
  margin-bottom: 4rpx;
}

.month-card.today .month-name {
  color: rgba(255, 255, 255, 0.8);
}

.month-cups {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--coffee-darker);
}

.month-card.today .month-cups {
  color: #FFF;
}

.month-shops {
  font-size: 16rpx;
  color: var(--coffee-light);
}

.month-card.today .month-shops {
  color: rgba(255, 255, 255, 0.7);
}

.login-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: linear-gradient(135deg, var(--coffee-dark) 0%, var(--coffee-medium) 100%);
  border-radius: 50rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(139, 90, 43, 0.2);
}

.login-btn::after {
  border: none;
}

.btn-icon {
  font-size: 28rpx;
}

.btn-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #FFF;
}

.skip-btn {
  text-align: center;
  font-size: 24rpx;
  color: var(--coffee-light);
  padding: 12rpx;
}

.skip-btn:active {
  color: var(--coffee-dark);
}

.footer-text {
  text-align: center;
  font-size: 20rpx;
  color: var(--coffee-light);
  padding: 12rpx 0;
}
