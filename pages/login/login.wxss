.container {
  min-height: 100vh;
  background: var(--coffee-bg);
  padding: 24rpx;
  box-sizing: border-box;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.nav-left {
  width: 64rpx;
  height: 64rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--coffee-darker);
  letter-spacing: 2rpx;
}

.nav-home {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF;
  border-radius: 50%;
  box-shadow: 0 2rpx 12rpx rgba(139, 90, 43, 0.1);
}

.home-icon {
  font-size: 28rpx;
}

.nav-home:active {
  background: var(--coffee-lightest);
}

.login-header {
  text-align: center;
  padding: 48rpx 0 32rpx;
}

.logo-icon {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.login-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--coffee-darker);
  margin-bottom: 12rpx;
}

.login-subtitle {
  font-size: 26rpx;
  color: var(--coffee-light);
}

.login-card {
  background: #FFF;
  border-radius: 24rpx;
  padding: 16rpx 32rpx;
  margin: 24rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(139, 90, 43, 0.08);
}

.input-group {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  transition: all 0.3s ease;
}

.input-group.focused .input-icon {
  transform: scale(1.1);
}

.input-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  transition: transform 0.3s ease;
}

.input-field {
  flex: 1;
  font-size: 30rpx;
  color: var(--coffee-darker);
  height: 48rpx;
  line-height: 48rpx;
}

.input-placeholder {
  color: var(--coffee-light);
  font-size: 28rpx;
}

.input-divider {
  height: 2rpx;
  background: var(--coffee-lightest);
  margin: 0 -8rpx;
}

.forgot-password {
  text-align: right;
  font-size: 24rpx;
  color: var(--coffee-medium);
  padding: 8rpx 8rpx 16rpx;
}

.forgot-password:active {
  color: var(--coffee-dark);
}

.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--coffee-dark) 0%, var(--coffee-medium) 100%);
  color: #FFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 50rpx;
  padding: 24rpx;
  margin-top: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(139, 90, 43, 0.3);
  letter-spacing: 8rpx;
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  transform: scale(0.98);
  opacity: 0.95;
}

.register-tip {
  text-align: center;
  font-size: 26rpx;
  color: var(--coffee-light);
  padding: 32rpx 0;
}

.register-link {
  color: var(--coffee-dark);
  font-weight: 600;
}

.register-tip:active {
  color: var(--coffee-darker);
}

.footer-text {
  text-align: center;
  font-size: 22rpx;
  color: var(--coffee-light);
  padding: 16rpx 0;
  margin-top: 24rpx;
}
