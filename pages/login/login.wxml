<view class="container">
  <view class="nav-bar">
    <view class="nav-left"></view>
    <view class="nav-title">Brewlog</view>
    <view class="nav-home" bindtap="goHome">
      <text class="home-icon">🏠</text>
    </view>
  </view>

  <view class="login-header">
    <view class="logo-icon">☕</view>
    <view class="login-title">欢迎回来</view>
    <view class="login-subtitle">登录你的咖啡手帐</view>
  </view>

  <view class="login-card">
    <view class="input-group {{phoneFocused ? 'focused' : ''}}">
      <text class="input-icon">📱</text>
      <input 
        class="input-field"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        placeholder-class="input-placeholder"
        value="{{phone}}"
        bindinput="onPhoneInput"
        bindfocus="onPhoneFocus"
        bindblur="onPhoneBlur"
      />
    </view>

    <view class="input-divider"></view>

    <view class="input-group {{passwordFocused ? 'focused' : ''}}">
      <text class="input-icon">🔒</text>
      <input 
        class="input-field"
        password="{{true}}"
        placeholder="请输入密码"
        placeholder-class="input-placeholder"
        value="{{password}}"
        bindinput="onPasswordInput"
        bindfocus="onPasswordFocus"
        bindblur="onPasswordBlur"
      />
    </view>
  </view>

  <view class="forgot-password" bindtap="goToForgotPassword">
    忘记密码？
  </view>

  <button class="login-btn" bindtap="doLogin">
    <text>登 录</text>
  </button>

  <view class="register-tip" bindtap="goToRegister">
    还没有账号？<text class="register-link">去注册</text>
  </view>

  <view class="footer-text">
    登录即表示同意《用户协议》和《隐私政策》
  </view>
</view>
