.container {
  min-height: 100vh;
  background: var(--coffee-bg);
  padding: 24rpx;
  box-sizing: border-box;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.nav-left {
  width: 64rpx;
  height: 64rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--coffee-darker);
  letter-spacing: 2rpx;
}

.nav-home {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF;
  border-radius: 50%;
  box-shadow: 0 2rpx 12rpx rgba(139, 90, 43, 0.1);
}

.home-icon {
  font-size: 28rpx;
}

.nav-home:active {
  background: var(--coffee-lightest);
}

.year-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 16rpx 20rpx;
  background: #FFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(139, 90, 43, 0.06);
}

.year-nav {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.year-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--coffee-lightest);
  border-radius: 50%;
  font-size: 28rpx;
  color: var(--coffee-darker);
}

.year-btn:active {
  background: var(--coffee-light);
}

.year-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--coffee-darker);
}

.year-stats {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--coffee-darker);
}

.stat-label {
  font-size: 20rpx;
  color: var(--coffee-light);
}

.this-month-summary {
  text-align: center;
  margin-bottom: 24rpx;
  padding: 16rpx;
  background: #FFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(139, 90, 43, 0.06);
}

.summary-text {
  font-size: 26rpx;
  color: var(--coffee-darker);
  font-weight: 500;
}

.months-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.month-card {
  background: #FFF;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(139, 90, 43, 0.06);
}

.month-card.today {
  background: linear-gradient(135deg, var(--coffee-dark) 0%, var(--coffee-medium) 100%);
}

.month-card.empty {
  opacity: 0.6;
}

.month-card:active {
  transform: scale(0.95);
}

.month-name {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--coffee-light);
  margin-bottom: 8rpx;
}

.month-card.today .month-name {
  color: rgba(255, 255, 255, 0.8);
}

.month-cups {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--coffee-darker);
  margin-bottom: 4rpx;
}

.month-card.today .month-cups {
  color: #FFF;
}

.month-shops {
  font-size: 20rpx;
  color: var(--coffee-light);
}

.month-card.today .month-shops {
  color: rgba(255, 255, 255, 0.7);
}
