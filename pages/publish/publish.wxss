.container {
  min-height: 100vh;
  background: var(--coffee-bg);
  padding-bottom: 40rpx;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #FFF;
  border-bottom: 2rpx solid var(--coffee-lightest);
}

.nav-cancel,
.nav-publish {
  padding: 8rpx 16rpx;
  font-size: 28rpx;
}

.nav-cancel text {
  color: var(--coffee-light);
}

.nav-publish {
  background: linear-gradient(135deg, var(--coffee-dark) 0%, var(--coffee-medium) 100%);
  color: #FFF;
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
  font-weight: 600;
  font-size: 26rpx;
}

.nav-publish:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--coffee-darker);
}

/* 文案输入 */
.text-section {
  background: #FFF;
  padding: 24rpx 32rpx;
  margin: 16rpx 0;
  position: relative;
}

.text-input {
  width: 100%;
  min-height: 200rpx;
  font-size: 30rpx;
  color: var(--coffee-darker);
  line-height: 1.6;
  padding: 8rpx 0;
}

.text-placeholder {
  color: var(--coffee-light);
  font-size: 28rpx;
}

.text-counter {
  text-align: right;
  font-size: 22rpx;
  color: var(--coffee-light);
  margin-top: 8rpx;
}

/* 通用 section */
.section-title {
  font-size: 26rpx;
  color: var(--coffee-medium);
  font-weight: 600;
  margin-bottom: 16rpx;
}

/* 图片选择 */
.image-section {
  background: #FFF;
  padding: 24rpx 32rpx;
  margin: 16rpx 0;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, var(--coffee-lightest) 0%, #FFF5E6 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  border: 2rpx solid var(--coffee-lightest);
}

.image-content {
  font-size: 96rpx;
}

.image-remove {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 40rpx;
  height: 40rpx;
  background: var(--coffee-darker);
  color: #FFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  line-height: 1;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  background: #FFF;
  border: 2rpx dashed var(--coffee-light);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.image-add:active {
  background: var(--coffee-lightest);
}

.add-icon {
  font-size: 64rpx;
  color: var(--coffee-light);
  line-height: 1;
}

.add-text {
  font-size: 22rpx;
  color: var(--coffee-light);
  margin-top: 8rpx;
}

/* 位置选择 */
.location-section {
  background: #FFF;
  padding: 24rpx 32rpx;
  margin: 16rpx 0;
}

.location-empty,
.location-active {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--coffee-lightest);
  border-radius: 16rpx;
}

.location-empty:active,
.location-active:active {
  background: #F0DCC0;
}

.location-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.location-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--coffee-medium);
}

.location-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.location-name {
  font-size: 28rpx;
  color: var(--coffee-darker);
  font-weight: 600;
}

.location-address {
  font-size: 22rpx;
  color: var(--coffee-light);
  margin-top: 4rpx;
}

.location-arrow {
  font-size: 36rpx;
  color: var(--coffee-light);
}

.location-clear {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--coffee-darker);
  color: #FFF;
  border-radius: 50%;
  font-size: 32rpx;
}

/* 提示 */
.tip-section {
  padding: 24rpx 32rpx;
}

.tip-text {
  font-size: 22rpx;
  color: var(--coffee-light);
}
