<view class="container">
  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="nav-cancel" bindtap="onCancel">
      <text>取消</text>
    </view>
    <view class="nav-title">发布动态</view>
    <view class="nav-publish" bindtap="onPublish">
      <text>发布</text>
    </view>
  </view>

  <!-- 文案输入 -->
  <view class="text-section">
    <textarea 
      class="text-input"
      placeholder="分享你的咖啡时刻..."
      placeholder-class="text-placeholder"
      maxlength="{{maxTextLength}}"
      value="{{text}}"
      bindinput="onTextInput"
      auto-height
    />
    <view class="text-counter">{{textLength}}/{{maxTextLength}}</view>
  </view>

  <!-- 图片选择 -->
  <view class="image-section">
    <view class="section-title">添加图片</view>
    <view class="image-grid">
      <view 
        class="image-item" 
        wx:for="{{images}}" 
        wx:key="*this"
        wx:for-index="idx"
      >
        <text class="image-content">{{item}}</text>
        <view class="image-remove" catchtap="removeImage" data-index="{{idx}}">
          <text>×</text>
        </view>
      </view>
      <view 
        class="image-add" 
        wx:if="{{images.length < 9}}"
        bindtap="chooseImage"
      >
        <text class="add-icon">+</text>
        <text class="add-text">{{images.length}}/9</text>
      </view>
    </view>
  </view>

  <!-- 位置选择 -->
  <view class="location-section">
    <view class="section-title">位置</view>
    <view wx:if="{{!location}}" class="location-empty" bindtap="chooseLocation">
      <text class="location-icon">📍</text>
      <text class="location-text">点击选择咖啡店位置</text>
      <text class="location-arrow">›</text>
    </view>
    <view wx:else class="location-active" bindtap="chooseLocation">
      <text class="location-icon">📍</text>
      <view class="location-info">
        <text class="location-name">{{location}}</text>
        <text wx:if="{{locationAddress}}" class="location-address">{{locationAddress}}</text>
      </view>
      <view class="location-clear" catchtap="clearLocation">
        <text>×</text>
      </view>
    </view>
  </view>

  <!-- 提示 -->
  <view class="tip-section">
    <text class="tip-text">💡 静态演示版：图片用 emoji 模拟，位置可手动输入</text>
  </view>
</view>
