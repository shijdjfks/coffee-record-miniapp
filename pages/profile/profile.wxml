<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="avatar-wrapper">
      <image class="avatar" src="{{avatarUrl}}" mode="aspectFill"></image>
    </view>
    <view class="user-info">
      <text class="nickname">{{nickName || '未登录'}}</text>
      <text class="bio">咖啡爱好者 ☕</text>
    </view>
    <button class="login-tip-btn" wx:if="{{!nickName}}" bindtap="login">
      点击登录
    </button>
  </view>

  <!-- 统计概览 -->
  <view class="stats-row">
    <view class="stat-item">
      <text class="stat-num">{{totalCups}}</text>
      <text class="stat-label">总杯数</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{totalShops}}</text>
      <text class="stat-label">到店数</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{daysActive}}</text>
      <text class="stat-label">打卡天数</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-group">
    <view class="menu-item" bindtap="goToYear">
      <text class="menu-icon">📅</text>
      <text class="menu-text">我的年视图</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToWeek">
      <text class="menu-icon">📆</text>
      <text class="menu-text">我的周视图</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToAdd">
      <text class="menu-icon">✏️</text>
      <text class="menu-text">添加记录</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-group">
    <view class="menu-item" bindtap="showAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于 Brewlog</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
